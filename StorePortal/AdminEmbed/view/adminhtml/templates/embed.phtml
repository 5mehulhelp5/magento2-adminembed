<?php
/**
 * Store Portal embed template.
 * Loads the portal dashboard inside Magento Admin via an auto-login iframe.
 *
 * @var \Magento\Backend\Block\Template $block
 */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
/** @var \StorePortal\AdminEmbed\Helper\Token $tokenHelper */
$tokenHelper = $objectManager->get(\StorePortal\AdminEmbed\Helper\Token::class);
$iframeUrl   = $tokenHelper->getIframeUrl('/dashboard');
$portalUrl   = $tokenHelper->getPortalUrl();
?>
<style>
  #sp-wrap {
    position: relative;
    width: 100%;
    height: calc(100vh - 140px);
    min-height: 620px;
    background: #f0f0f1;
    border: 1px solid #dcdcde;
    border-radius: 4px;
    overflow: hidden;
  }
  #sp-frame {
    width: 100%;
    height: 100%;
    border: none;
    opacity: 0;
    transition: opacity .3s;
  }
  #sp-loading {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #f0f0f1;
    color: #787c82;
    gap: 1rem;
    pointer-events: none;
  }
  .sp-spinner {
    width: 32px; height: 32px;
    border: 3px solid #dcdcde;
    border-top-color: #2271b1;
    border-radius: 50%;
    animation: sp-spin .8s linear infinite;
  }
  @keyframes sp-spin { to { transform: rotate(360deg); } }
  #sp-error {
    display: none;
    text-align: center;
    padding: 3rem 2rem;
    background: #fff;
    border: 1px solid #dcdcde;
    border-radius: 4px;
  }
  #sp-error h2 { color: #1d2327; font-size: 1.2rem; margin-bottom: .5rem; }
  #sp-error p  { color: #787c82; font-size: .9rem; margin-bottom: 1.2rem; }
</style>

<div id="sp-wrap">
  <iframe id="sp-frame"
          src="<?= $block->escapeUrl($iframeUrl) ?>"
          title="Store Portal Dashboard"
          frameborder="0"
          allowfullscreen>
  </iframe>
  <div id="sp-loading">
    <div class="sp-spinner"></div>
    <p>Loading Store Portal…</p>
  </div>
</div>

<div id="sp-error">
  <h2>⚠ Could not load Store Portal</h2>
  <p>Make sure the Store Portal server is running at <strong><?= $block->escapeHtml($portalUrl) ?></strong></p>
  <a href="<?= $block->escapeUrl($iframeUrl) ?>" target="_blank" class="action-primary">
    Open in new tab ↗
  </a>
</div>

<script>
(function () {
  var frame   = document.getElementById('sp-frame');
  var loading = document.getElementById('sp-loading');
  var wrap    = document.getElementById('sp-wrap');
  var errBox  = document.getElementById('sp-error');
  var timer;

  function onLoad() {
    clearTimeout(timer);
    loading.style.display = 'none';
    frame.style.opacity = '1';
  }

  function onError() {
    clearTimeout(timer);
    wrap.style.display = 'none';
    errBox.style.display = 'block';
  }

  // Timeout fallback: if iframe hasn't loaded in 15s, show error
  timer = setTimeout(onError, 15000);
  frame.addEventListener('load', onLoad);
  frame.addEventListener('error', onError);
})();
</script>
