<script>
(function () {
  var frame   = document.getElementById('sp-frame');
  var loading = document.getElementById('sp-loading');
  var wrap    = document.getElementById('sp-wrap');
  var errBox  = document.getElementById('sp-error');
  var timer;
  var iframeLoaded = false;

  function onLoad() {
    if (iframeLoaded) return;   // fire once only
    iframeLoaded = true;
    clearTimeout(timer);
    if (loading) loading.style.display = 'none';
    frame.style.opacity = '1';
  }

  function onError() {
    clearTimeout(timer);
    if (wrap)   wrap.style.display   = 'none';
    if (errBox) errBox.style.display = 'block';
  }

  /* Licensed state: frame already has src, start timer immediately */
  if (frame && frame.getAttribute('src')) {
    timer = setTimeout(onError, 15000);
    frame.addEventListener('load',  onLoad);
    frame.addEventListener('error', onError);
  }

  /* Listen for postMessage from the portal iframe (cross-origin safe) */
  window.addEventListener('message', function (e) {
    if (e.data && e.data.action === 'reloadPortal') {
      window.location.reload();
    }
    /* After payment: navigate to Magento license config page */
    if (e.data && e.data.action === 'goToSettings') {
      window.location.href = <?= json_encode($licenseConfigUrl) ?>;
    }
  });

  /* Unlicensed state: button click loads the iframe */
  window.showSelectPlan = function () {
    var banner = document.getElementById('sp-locked-banner');
    if (banner) banner.style.display = 'none';
    if (wrap)   wrap.style.display   = 'block';

    /* frame has no src yet (no src attribute in HTML) — set it now */
    var targetSrc = frame.getAttribute('data-src');
    if (targetSrc && !frame.getAttribute('src')) {
      /* Append current Magento admin URL so Flask stores it and passes it to Stripe success page */
      var sep = targetSrc.indexOf('?') !== -1 ? '&' : '?';
      targetSrc = targetSrc + sep + 'return_url=' + encodeURIComponent(window.location.href)
                + '&settings_url=' + encodeURIComponent(<?= json_encode($licenseConfigUrl) ?>);
      frame.setAttribute('src', targetSrc);
      /* Start a fresh 15-second timeout from the moment the user clicked */
      timer = setTimeout(onError, 15000);
      frame.addEventListener('load',  onLoad);
      frame.addEventListener('error', onError);
    }
  };
})();
</script>
