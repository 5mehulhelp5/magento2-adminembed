/**
 * Store Portal embed template — shared by Dashboard, Auto Sync, and Bulk Sync pages.
 * Pass data argument "portal_path" from layout XML to control which portal page loads.
 *
 * @var \Magento\Backend\Block\Template $block
 */
$objectManager = \Magento\Framework\App\ObjectManager::getInstance();
/** @var \StorePortal\AdminEmbed\Helper\Token $tokenHelper */
$tokenHelper     = $objectManager->get(\StorePortal\AdminEmbed\Helper\Token::class);
$portalPath      = $block->getData('portal_path') ?: '/dashboard';
$portalUrl       = $tokenHelper->getPortalUrl();
$licenseValid    = $block->getData('license_valid') ?? $tokenHelper->isLicensed();
$licensePlan     = $block->getData('license_plan') ?? '';
$licenseMessage  = $block->getData('license_message') ?? '';
$settingsUrl     = $block->getData('portal_settings_url') ?? '#';
$licenseConfigUrl = $block->getUrl('adminhtml/system_config/edit', ['section' => 'storeportal']);
// Extract Magento store domain so select-plan can pre-fill and match subscription
$storeManager = $objectManager->get(\Magento\Store\Model\StoreManagerInterface::class);
$storeUrl = $storeManager->getStore()->getBaseUrl();
$parsed = parse_url($storeUrl);
$storeDomain = ($parsed['host'] ?? 'localhost') . (isset($parsed['port']) ? ':' . $parsed['port'] : '');
$iframeUrl       = $licenseValid ? $tokenHelper->getIframeUrl($portalPath) : $portalUrl . '/select-plan?domain=' . urlencode($storeDomain);
?>
