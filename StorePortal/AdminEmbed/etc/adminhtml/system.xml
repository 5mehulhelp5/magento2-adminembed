<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <!-- Hang under the shared eTechFlow config tab (declared by every eTechFlow
             module; tabs merge by id) instead of a standalone Store Portal tab. -->
        <tab id="etechflow" translate="label" sortOrder="200">
            <label>Etechflow</label>
        </tab>
        <section id="storeportal" translate="label" sortOrder="200" showInDefault="1" showInWebsite="0" showInStore="0">
            <label>Store Portal</label>
            <tab>etechflow</tab>
            <resource>StorePortal_AdminEmbed::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General Settings</label>
                <field id="portal_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Portal URL</label>
                    <comment>Base URL of your Store Portal Flask app (e.g. http://localhost:5000 or your ngrok URL). No trailing slash.</comment>
                </field>
                <field id="api_key" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Key</label>
                    <comment>Must match WP_PLUGIN_API_KEY in your Flask .env file.</comment>
                </field>
            </group>

            <group id="license" translate="label" sortOrder="5" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <field id="license_key" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[Paste your eTechFlow SP-XXXX subscription key (auto-saved after Stripe payment) or a per-module/bundle HMAC key.]]></comment>
                </field>
                <field id="issued_key" translate="label comment" type="obscure" sortOrder="15" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Issued Key (auto)</label>
                    <comment><![CDATA[Set automatically after successful payment. Do not edit.]]></comment>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="portal_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[Base URL of the eTechFlow licensing portal (used for /license/plans and /license/validate). No trailing slash.]]></comment>
                </field>
                <field id="portal_api_url" translate="label comment" type="text" sortOrder="25" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal API URL</label>
                    <comment><![CDATA[Optional override for the licensing API base. Defaults to the License Portal URL.]]></comment>
                </field>
            </group>

        </section>
    </system>
</config>
