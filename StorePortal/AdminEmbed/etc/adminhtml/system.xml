<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="storeportal" translate="label" sortOrder="200">
            <label>Store Portal</label>
        </tab>
        <section id="storeportal" translate="label" sortOrder="200" showInDefault="1" showInWebsite="0" showInStore="0">
            <label>Store Portal</label>
            <tab>storeportal</tab>
            <resource>StorePortal_AdminEmbed::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>General Settings</label>
                <field id="portal_url" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Portal URL</label>
                    <comment>Base URL of your Store Portal Flask app (e.g. http://localhost:5000 or your ngrok URL). No trailing slash.</comment>
                </field>
                <field id="api_key" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>API Key</label>
                    <comment>Must match WP_PLUGIN_API_KEY in your Flask .env file.</comment>
                </field>
            </group>
            <group id="license" translate="label" sortOrder="100" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>License</label>
                <field id="license_key" translate="label comment" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>License Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>Paste your Store Portal license key. Obtain it from your Store Portal admin at /admin/licensing.</comment>
                </field>
                <field id="production_environment" translate="label comment" type="select" sortOrder="20" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Production Environment</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Set to Yes on live/production stores. Dev/staging environments bypass licensing automatically.</comment>
                </field>
            </group>
        </section>
        <!-- Bundle license — shared across all StorePortal modules -->
        <section id="storeportal_bundle" translate="label" sortOrder="201" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Store Portal — Bundle License</label>
            <tab>storeportal</tab>
            <resource>StorePortal_AdminEmbed::config</resource>
            <group id="license" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Bundle Key (All-Channels / Enterprise)</label>
                <field id="license_key" translate="label comment" type="obscure" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                    <label>Bundle License Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment>For All-Channels and Enterprise plans — one bundle key activates all StorePortal modules. Leave blank if using a per-module key above.</comment>
                </field>
            </group>
        </section>
    </system>
</config>
