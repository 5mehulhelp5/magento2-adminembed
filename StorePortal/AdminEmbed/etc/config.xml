<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Store:etc/config.xsd">
    <default>
        <storeportal>
            <general>
                <!--
                  The embed Store Portal URL and its HMAC api_key are deployment specific
                  secrets and must not be committed. Set them per install with the
                  config:set lock-env command for storeportal/general/portal_url and
                  storeportal/general/api_key; lock-env stores the value in app/etc/env.php,
                  which is git ignored.
                -->
            </general>
            <license>
                <portal_api_url>https://license-service.etechflow.com</portal_api_url>
            </license>
        </storeportal>
    </default>
</config>
